# SPDX-License-Identifier: GPL-3.0-or-later
#
# Pinned configuration for the zlib dogfooding target (Stage 2).
# A dogfooding configuration is (base image digest, target source revision,
# target build type); all are pinned so the golden stays stable
# (dogfood-pinned-target). Sourced by run.sh; values are also consumed by
# the target Containerfile via podman build --build-arg.

# Pinned base image: this digest IS fedora:44 (the devcontainer base).
# An unpinned base would let a package update change the compiler under a
# fixed golden and produce phantom diffs.
BASE_IMAGE="registry.fedoraproject.org/fedora@sha256:3baf5f0dededfd939eb8f0b271ff8ad17bdb381cdd5768bd7d6f45bba795aa62"

# Pinned zlib source.
ZLIB_VERSION="1.3.1"
ZLIB_URL="https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz"
ZLIB_SHA256="9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23"

# Pinned build type. Release is representative of shipped use.
BUILD_TYPE="Release"

# Fixed in-container build path (dogfood-fixed-paths). zlib builds in-tree;
# its ./configure has no usable out-of-tree mode, so source and build share
# this path. A fixed path keeps absolute paths in 'directory' reproducible.
SRC_DIR="/src"

# Build directory passed to the replay sampler (dogfood-replay) as
# `cdb-compare sample --build-dir`, so it prefers TUs whose flags do not
# reference build-dir includes. zlib builds in-tree, so its build dir IS /src.
# shellcheck disable=SC2034
BUILD_DIR="/src"

# Object-count instrument for the entry-count invariant (dogfood-invariants).
# OBJECTS_DIR is where zlib's objects live, but a post-build `find` is the WRONG
# instrument for zlib: its in-tree make compiles each library source twice (a
# static *.o and a PIC objs/*.o) but DELETES the whole objs/ directory at link
# time, so only the 19 static objects survive while 34 are produced - a ~1.8x
# undercount no sane tolerance should absorb. So zlib overrides OBJECT_COUNT_CMD
# to count make's OWN dependency graph (`make -Bn` lists every compile rule),
# which is the build-system-native, cleanup-independent, Bear-independent count
# of objects produced (34). It is run after the real build (the configure cache
# is already in place). OBJECTS_DIR is retained for documentation / the default.
# shellcheck disable=SC2034
OBJECTS_DIR="/src"
# shellcheck disable=SC2034
# `grep -oE -e PATTERN`: -e marks the pattern so grep does not mistake the
# leading "-o " for its own -o option.
OBJECT_COUNT_CMD="cd /src && make -Bn 2>/dev/null | grep -oE -e '-o [^ ]+\\.o' | sort -u | wc -l"

# Tolerance percent for the entry-count band
# (--expected-objects N --tolerance OBJECT_TOLERANCE_PCT). With OBJECT_COUNT_CMD
# counting produced objects (34) and Bear recording 34 entries, the two match
# exactly; 10% is headroom for an incidental build-system object and keeps the
# check sensitive to a real entry drop or duplication. Deliberately small:
# over-wide tolerance would hide a real drop.
# shellcheck disable=SC2034
OBJECT_TOLERANCE_PCT="10"

# Per-target preflight minimum free disk on the podman graphroot, in KiB
# (dogfood-preflight). zlib needs roughly 2 GiB for the base + target images.
MIN_FREE_KIB="2097152"

# The build command run INSIDE the target container, wrapped by Bear. zlib's
# configure passes CFLAGS through; Release maps to -O3 -DNDEBUG. The output
# lands at /out/compile_commands.json, copied out with 'podman cp'.
#
# INJECT_CFLAGS is the determinism self-test hook (dogfood-determinism): it is
# empty on every normal run and on determinism run 1, and carries a perturbing
# flag on determinism run 2 under --inject-fault, so the two captures diverge
# and the check is shown to FAIL. It is appended to the configure-time CFLAGS so
# it lands in the recorded compiler arguments.
# shellcheck disable=SC2034
TARGET_BUILD_CMD='cd /src && CFLAGS="-O3 -DNDEBUG ${INJECT_CFLAGS:-}" ./configure && bear --output /out/compile_commands.json -- make'
