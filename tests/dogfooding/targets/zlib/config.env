# SPDX-License-Identifier: GPL-3.0-or-later
#
# Pinned configuration for the zlib dogfooding target (Stage 2).
# A dogfooding configuration is (base image digest, target source revision,
# target build type); all are pinned so the golden stays stable
# (dogfood-pinned-target). Sourced by run.sh; values are also consumed by
# the target Containerfile via podman build --build-arg.

# Pinned base image: this digest IS fedora:44 (the devcontainer base).
# An unpinned base would let a package update change the compiler under a
# fixed golden and produce phantom diffs.
BASE_IMAGE="registry.fedoraproject.org/fedora@sha256:3baf5f0dededfd939eb8f0b271ff8ad17bdb381cdd5768bd7d6f45bba795aa62"

# Pinned zlib source.
ZLIB_VERSION="1.3.1"
ZLIB_URL="https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz"
ZLIB_SHA256="9a93b2b7dfdac77ceba5a558a580e74667dd6fede4585b91eefb60f03b72df23"

# Pinned build type. Release is representative of shipped use.
BUILD_TYPE="Release"

# Fixed in-container build path (dogfood-fixed-paths). zlib builds in-tree;
# its ./configure has no usable out-of-tree mode, so source and build share
# this path. A fixed path keeps absolute paths in 'directory' reproducible.
SRC_DIR="/src"

# Per-target preflight minimum free disk on the podman graphroot, in KiB
# (dogfood-preflight). zlib needs roughly 2 GiB for the base + target images.
MIN_FREE_KIB="2097152"

# The build command run INSIDE the target container, wrapped by Bear. zlib's
# configure passes CFLAGS through; Release maps to -O3 -DNDEBUG. The output
# lands at /out/compile_commands.json, copied out with 'podman cp'.
# shellcheck disable=SC2034
TARGET_BUILD_CMD='cd /src && CFLAGS="-O3 -DNDEBUG" ./configure && bear --output /out/compile_commands.json -- make'
