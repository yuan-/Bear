# SPDX-License-Identifier: GPL-3.0-or-later
#
# Pinned configuration for the curl dogfooding target (Stage 3, oracle).
# A dogfooding configuration is (base image digest, target source revision,
# target build type); all are pinned so the comparison stays stable
# (dogfood-pinned-target). Sourced by run.sh; values are also consumed by the
# target Containerfile via podman build --build-arg.

# Validation mode for this target: 'oracle' compares Bear's capture against
# the database CMake itself emits (CMAKE_EXPORT_COMPILE_COMMANDS=ON), scoped to
# the intersection of translation units (dogfood-oracle-cmake). zlib uses
# 'golden'. run.sh dispatches on this selector.
VALIDATION="oracle"

# Pinned base image: the same digest zlib uses (this IS fedora:44, the
# devcontainer base). An unpinned base would let a package update change the
# compiler under a fixed comparison and produce phantom diffs.
BASE_IMAGE="registry.fedoraproject.org/fedora@sha256:3baf5f0dededfd939eb8f0b271ff8ad17bdb381cdd5768bd7d6f45bba795aa62"

# Pinned curl source.
CURL_VERSION="8.11.1"
CURL_URL="https://github.com/curl/curl/releases/download/curl-8_11_1/curl-8.11.1.tar.gz"
CURL_SHA256="a889ac9dbba3644271bd9d1302b5c22a088893719b72be3487bc3d401e5c4e80"

# Pinned build type. Release is representative of shipped use.
BUILD_TYPE="Release"

# Fixed in-container paths (dogfood-fixed-paths). curl builds with CMake, which
# supports out-of-tree builds, so source and build are separate fixed paths.
# Fixed paths keep absolute paths in 'directory'/'file' reproducible. BUILD_DIR
# is also the build dir passed to the replay sampler (dogfood-replay) as
# `cdb-compare sample --build-dir`, so it prefers TUs whose flags do not
# reference build-dir includes (more of curl's TUs then replay cleanly).
SRC_DIR="/src"
BUILD_DIR="/build"

# Object-count instrument for the entry-count invariant (dogfood-invariants).
# curl's CMake build leaves every object on disk under the out-of-tree build
# dir /build (CMakeFiles/*.dir/*.o), so the DEFAULT instrument - a post-build
# `find $OBJECTS_DIR -name '*.o' | wc -l` - is exact; curl does NOT override
# OBJECT_COUNT_CMD. (Contrast zlib, which deletes its PIC objects and must count
# make's dependency graph instead.)
# shellcheck disable=SC2034
OBJECTS_DIR="/build"

# Tolerance percent for the entry-count band
# (--expected-objects N --tolerance OBJECT_TOLERANCE_PCT). curl compiles most
# library sources twice (a shared-lib PIC object and a static object), so the
# entry count tracks the object count closely; 10% absorbs CMake's own
# feature-probe scratch objects (CMakeScratch / try_compile) that land under
# /build but are not library TUs, without a false fail.
# shellcheck disable=SC2034
OBJECT_TOLERANCE_PCT="10"

# Per-target preflight minimum free disk on the podman graphroot, in KiB
# (dogfood-preflight). curl needs more than zlib: base + target images plus a
# full CMake configure+build tree. ~4 GiB is a safe floor.
MIN_FREE_KIB="4194304"

# The build command run INSIDE the target container. Two phases:
#
#  1. CMake CONFIGURE (NOT wrapped by Bear - configure is not a compile). It
#     emits CMake's own oracle database at /build/compile_commands.json via
#     CMAKE_EXPORT_COMPILE_COMMANDS=ON. Optional dependencies are turned OFF so
#     curl configures and builds with just cmake + gcc + make: no TLS backend,
#     no nghttp2/zlib/zstd/brotli/psl/idn/ssh/ldap/librtmp. This keeps the
#     image minimal and the build deterministic.
#  2. BUILD wrapped by Bear -> Bear's capture at /out/compile_commands.json.
#
# Finally CMake's oracle DB is copied to /out/oracle.json. Both DBs are pulled
# out of the stopped container with 'podman cp'. run.sh's oracle branch then
# compares them on the intersection of files.
#
# INJECT_CFLAGS is the determinism self-test hook (dogfood-determinism): empty
# on every normal run and on determinism run 1, it carries a perturbing flag on
# determinism run 2 under --inject-fault. It is appended to CMAKE_C_FLAGS so it
# lands in the recorded compiler arguments and the two captures diverge, showing
# the determinism check FAIL. /build is fresh each run (a new container), so the
# CMake cache is regenerated and the flag takes effect.
# shellcheck disable=SC2034
TARGET_BUILD_CMD='mkdir -p /out && cmake -S /src -B /build -DCMAKE_BUILD_TYPE=Release -DCMAKE_C_FLAGS="${INJECT_CFLAGS:-}" -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCURL_USE_OPENSSL=OFF -DCURL_USE_LIBSSH2=OFF -DCURL_USE_LIBSSH=OFF -DCURL_USE_LIBPSL=OFF -DCURL_USE_GSSAPI=OFF -DUSE_NGHTTP2=OFF -DUSE_LIBIDN2=OFF -DCURL_BROTLI=OFF -DCURL_ZSTD=OFF -DCURL_ZLIB=OFF -DUSE_LIBRTMP=OFF -DCURL_DISABLE_LDAP=ON -DCURL_DISABLE_LDAPS=ON -DBUILD_CURL_EXE=ON -DBUILD_SHARED_LIBS=ON && bear --output /out/compile_commands.json -- cmake --build /build && cp /build/compile_commands.json /out/oracle.json'
