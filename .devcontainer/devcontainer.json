// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/rust
{
  "name": "Rust Dev Container (${localWorkspaceFolderBasename})",
  "build": {
    "dockerfile": "Dockerfile",
  },

  // Give the container a writable, delegated cgroup v2 subtree. By default
  // rootless Podman mounts /sys/fs/cgroup read-only, so a process cannot create
  // a child cgroup -- which the cgroup-based process-tree teardown path
  // (interception-signal-forwarding) needs in order to be developed and tested.
  //
  // --systemd=always makes Podman mount the container's own cgroup read-write
  // inside our private cgroup namespace (the cpu/io/memory/pids controllers are
  // already delegated by the kernel). Host prerequisite for rootless Podman:
  // controller delegation for the user session, e.g.
  //   /etc/systemd/system/user@.service.d/delegate.conf:
  //     [Service]
  //     Delegate=cpu cpuset io memory pids
  // (usually already in place -- the controllers above being visible confirms
  // it). Podman-specific flag.
  //
  // After changing this, rebuild the container and verify with:
  //   findmnt /sys/fs/cgroup        # should report rw
  //   mkdir "/sys/fs/cgroup$(awk -F: '/^0::/{print $3}' /proc/self/cgroup)/x"
  "runArgs": ["--systemd=always"],

  // Override the automatic workspace mount to add the :z SELinux relabel option.
  // This is required on Fedora/RHEL hosts where SELinux is enforcing, otherwise
  // the bind-mounted directory is inaccessible inside the container.
  // ${localWorkspaceFolderBasename} expands to the project directory name, so
  // this file stays generic across Rust projects.
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/${localWorkspaceFolderBasename},type=bind,z=true",

  "mounts": [
    // Persist the cargo registry (downloaded crate cache) across container
    // rebuilds. Targets the registry subdir of CARGO_HOME (/root/.cargo, set in
    // the Dockerfile) rather than /root/.cargo itself, so the volume does not
    // shadow the rustc/cargo binaries installed into /root/.cargo/bin at build.
    "source=devcontainer-cargo-cache-${devcontainerId},target=/root/.cargo/registry,type=volume",
    // Forward the SSH agent socket from the host so SSH keys are available
    // inside the container for commit signing and remote operations.
    // Requires the SSH agent to be running on the host: eval $(ssh-agent) && ssh-add
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind",
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly=true,z=true",
    // Mount the host gitconfig (read-only) so git user identity, signing key,
    // and gpg/ssh signing settings are inherited inside the container.
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,readonly=true,z=true",
    // Mount the host ~/.claude (read-write) so Claude credentials, settings,
    // rules, and skills are shared with the container. Writable so refreshed
    // auth tokens and session state persist back to the host, avoiding repeated
    // re-authentication across container rebuilds.
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind,z=true",
  ],

  // Point git at the forwarded SSH agent socket.
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent",
  },

  // In rootless Podman on Fedora/RHEL, container uid=0 (root) maps to the host
  // user's uid (laca, uid=1000). Running as root inside the container is therefore
  // safe and ensures the mounted project files are writable.
  "remoteUser": "root",
  "containerUser": "root",

  // Verify the Rust toolchain is available after the container is created.
  "postCreateCommand": "rustc --version && cargo --version",
}
